@use "./base.scss";

/* ===== 背景图 + Blue Topaz 氛围光 ===== */
html, body {
  background-image: url('static/bp.jpg') !important;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-attachment: fixed;
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

/* 更明显的蓝紫色光晕，模拟 Obsidian 的柔光 */
body::after {
  content: "";
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: radial-gradient(circle at 30% 40%, rgba(130, 170, 230, 0.25) 0%, transparent 55%),
              radial-gradient(circle at 70% 60%, rgba(180, 140, 220, 0.15) 0%, transparent 55%);
  z-index: -1;
  pointer-events: none;
}

.dark body::after {
  background: radial-gradient(circle at 30% 40%, rgba(80, 120, 200, 0.3) 0%, transparent 55%),
              radial-gradient(circle at 70% 60%, rgba(120, 90, 180, 0.2) 0%, transparent 55%);
}

/* ===== 侧边栏：自然折叠，悬停平滑展开 ===== */
#quartz-root .left {
  width: 55px;
  transition: width 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  transition-delay: 0.1s;
  overflow: hidden;
  background-color: rgba(245, 248, 252, 0.7);
  backdrop-filter: blur(12px);
  border-right: 1px solid rgba(58, 110, 165, 0.08);
  padding: 1rem 0.5rem;
  white-space: nowrap;
}

#quartz-root .left:hover {
  width: 250px;
  transition-delay: 0s;
}

/* ===== 内容区域：更宽、更饱满 ===== */
.page {
  background-color: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(16px);
  border-radius: 16px;
  padding: 2rem 2.5rem;         /* 减小内边距，让文字区域更饱满 */
  margin: 2rem auto;
  max-width: 1100px;            /* 主流博客宽度 */
  width: calc(100% - 4rem);     /* 保证小屏留边 */
  box-shadow: 0 4px 24px rgba(58, 110, 165, 0.06),
              0 0 0 1px rgba(58, 110, 165, 0.06);
}

.dark .page {
  background-color: rgba(30, 41, 59, 0.88);
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.3),
              0 0 0 1px rgba(107, 159, 212, 0.08);
}

/* 大屏时可以更宽 */
@media (min-width: 1600px) {
  .page {
    max-width: 1200px;
  }
}

/* ===== 右侧目录栏 ===== */
#quartz-root .right {
  width: 220px;
  padding: 1.5rem 1rem;
  background-color: rgba(245, 248, 252, 0.5);
  backdrop-filter: blur(8px);
  border-left: 1px solid rgba(58, 110, 165, 0.05);
}
.dark #quartz-root .right {
  background-color: rgba(26, 35, 50, 0.55);
}

/* ===== 正文排版 ===== */
body {
  font-family: "Inter", "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  font-size: 1.05em;
  line-height: 1.85;
  color: #2c3a4b !important;
  font-weight: 400;
}
.dark body {
  color: #d0d8e4 !important;
}

/* ===== 标题：衬线体，蓝宝石层次 ===== */
h1, h2, h3, h4, h5, h6 {
  font-family: "Noto Serif SC", serif;
  line-height: 1.4;
  margin-top: 1.8em;
  margin-bottom: 0.5em;
}
h1 { font-size: 2em; color: #08367c !important; font-weight: 800; }
h2 { font-size: 1.6em; color: #004faa !important; font-weight: 700; }
h3 { font-size: 1.3em; color: #0e64bb !important; font-weight: 700; }
h4 { font-size: 1.15em; color: #3481c5 !important; font-weight: 600; }
h5 { font-size: 1.05em; color: #59a0e2 !important; font-weight: 600; }
h6 { font-size: 0.95em; color: #88b8e6 !important; font-weight: 600; }

.dark h1 { color: #8fb9f0 !important; }
.dark h2 { color: #7aade6 !important; }
.dark h3 { color: #6a9fd4 !important; }
.dark h4 { color: #5b8fc2 !important; }
.dark h5 { color: #4e7fb0 !important; }
.dark h6 { color: #3e6f9e !important; }

.article-title {
  font-size: 2.2em;
  color: #08367c !important;
  font-weight: 800;
  line-height: 1.2;
}
.dark .article-title { color: #8fb9f0 !important; }

/* ===== 引用块 ===== */
blockquote {
  border-left: 3px solid #3a6ea5;
  background-color: rgba(58, 110, 165, 0.04);
  border-radius: 6px;
  padding: 1rem 1.5rem;
  margin: 2rem 0;
  font-style: italic;
}
.dark blockquote {
  border-left-color: #6b9fd4;
  background-color: rgba(107, 159, 212, 0.06);
}

/* ===== 代码块 ===== */
pre {
  border: 1px solid rgba(58, 110, 165, 0.1);
  border-radius: 10px;
  background-color: rgba(245, 248, 252, 0.5) !important;
  padding: 1.2rem 1.5rem;
  font-size: 0.95em;
}
.dark pre {
  background-color: rgba(0, 0, 0, 0.3) !important;
  border-color: rgba(107, 159, 212, 0.15);
}

code {
  font-family: "JetBrains Mono", monospace;
  font-size: 0.9em;
  background-color: rgba(58, 110, 165, 0.08);
  border-radius: 5px;
  padding: 0.15em 0.45em;
}
.dark code {
  background-color: rgba(107, 159, 212, 0.12);
}

/* ===== 标签 ===== */
.tag {
  display: inline-block;
  border-radius: 20px;
  padding: 0.2em 0.8em;
  font-size: 0.8em;
  font-weight: 500;
  background-color: rgba(58, 110, 165, 0.1);
  color: #3a6ea5;
  margin-right: 0.4em;
  margin-bottom: 0.3em;
  transition: all 0.2s;
}
.tag:hover {
  background-color: #3a6ea5;
  color: #fff;
}
.dark .tag {
  background-color: rgba(107, 159, 212, 0.15);
  color: #6b9fd4;
}
.dark .tag:hover {
  background-color: #6b9fd4;
  color: #fff;
}

/* ===== 链接 ===== */
a {
  color: #3a6ea5;
  text-decoration: none;
  border-bottom: 1px solid rgba(58, 110, 165, 0.25);
  transition: all 0.2s;
}
a:hover {
  color: #5d8fc0;
  border-bottom-color: #5d8fc0;
}
.dark a {
  color: #6b9fd4;
  border-bottom-color: rgba(107, 159, 212, 0.25);
}
.dark a:hover {
  color: #8ab8e8;
  border-bottom-color: #8ab8e8;
}

/* ===== 滚动条 ===== */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: rgba(0,0,0,0.02); }
::-webkit-scrollbar-thumb { background: #8b9bb5; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #3a6ea5; }

/* ===== 选中高亮 ===== */
::selection {
  background: #a0c4e888;
  color: #1e2a36;
}
.dark ::selection {
  background: #4a6a8a88;
  color: #e0e8f2;
}

/* ===== 悬浮预览窗 ===== */
.popover {
  border-radius: 12px;
  backdrop-filter: blur(12px);
  background-color: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(58, 110, 165, 0.1);
}
.dark .popover {
  background-color: rgba(30, 41, 59, 0.95);
  border: 1px solid rgba(107, 159, 212, 0.12);
}

/* ===== 移动端适配 ===== */
@media (max-width: 768px) {
  #quartz-root .left {
    width: 100%;
    position: fixed;
    z-index: 20;
    transition: none;
  }
  #quartz-root .left:hover {
    width: 100%;
  }
  #quartz-root .right {
    display: none;
  }
  .page {
    padding: 1.5rem 1.2rem;
    margin: 1rem auto;
    width: calc(100% - 1rem);
    border-radius: 10px;
  }
}
