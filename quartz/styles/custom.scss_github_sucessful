@use "./base.scss";

/* ===== 全局背景（清晰的 bp.jpg） ===== */
body {
  background-image: url('static/bp.jpg');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-attachment: fixed;
  /* 不添加遮罩，让背景原样显示 */
}

/* ===== 内容区域高不透明度卡片，隔绝背景干扰 ===== */
.page {
  background-color: rgba(245, 240, 232, 0.96);   /* 几乎不透，只留一丝透明感 */
  backdrop-filter: blur(12px);                   /* 卡片内部轻微模糊，让背景在卡片边缘若隐若现 */
  border-radius: 12px;
  padding: 1.5rem 2rem;
  margin: 1rem auto;
  max-width: 1000px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
}

.dark .page {
  background-color: rgba(15, 23, 34, 0.96);
  box-shadow: 0 4px 20px rgba(0,0,0,0.3);
}

/* 以下样式保持不变 */
.article-title {
  font-weight: 700;
  letter-spacing: -0.5px;
}

a {
  transition: color 0.2s ease;
}

pre {
  border: 1px solid var(--lightgray);
  border-radius: 8px;
}

::-webkit-scrollbar {
  width: 8px;
}
::-webkit-scrollbar-track {
  background: var(--lightgray);
}
::-webkit-scrollbar-thumb {
  background: var(--gray);
  border-radius: 4px;
}
::-webkit-scrollbar-thumb:hover {
  background: var(--darkgray);
}

.popover {
  border-radius: 10px;
  backdrop-filter: blur(8px);
  background-color: rgba(245, 240, 232, 0.95);
}
.dark .popover {
  background-color: rgba(15, 23, 34, 0.95);
}

.tag {
  border-radius: 20px;
  padding: 0.1em 0.6em;
  font-size: 0.8em;
  font-weight: 500;
  background-color: var(--highlight);
  transition: background-color 0.2s;
}
.tag:hover {
  background-color: var(--tertiary);
  color: var(--light);
}

body.slug-index .page {
  margin-top: 2rem;
}
